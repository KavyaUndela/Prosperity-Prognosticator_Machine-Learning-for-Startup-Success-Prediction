{
  "version": 2,
  "functions": {
    "api/index.py": {
      "excludeFiles": "{Startup_Success_Model.ipynb,README.md,*.md,setup.*,run.*,install_and_run.bat,*.sh}"
    }
  },
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
